{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://xtmusicapi.chikuu.top:3000/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://xtmusicapi.chikuu.top:3000/uploads/:path*"
    }
  ],
  "routes": [
    {
      "src": "/.well-known/(.*)",
      "dest": "/public/.well-known/$1",
      "headers": {
        "Content-Type": "application/json; charset=utf-8"
      }
    }
  ]
}